{
  "name": "@dukarun/frontend",
  "version": "2.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prestart": "node scripts/copy-ml-runtime.mjs",
    "build": "ng build",
    "prebuild": "node scripts/copy-ml-runtime.mjs",
    "ml:fetch-model": "node scripts/fetch-recognition-model.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:headless": "USE_HEADLESS=true ng test --watch=false",
    "test:ci": "CI=true ng test --code-coverage --watch=false --no-progress",
    "test:coverage": "ng test --code-coverage --watch=false",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts",
    "lint": "ng lint",
    "format": "prettier --write \"**/*.{ts,js,json,html,scss,css}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,html,scss,css}\"",
    "boundary-check": "node scripts/boundary-check.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.0.8",
    "@angular/compiler": "^21.0.8",
    "@angular/core": "^21.0.8",
    "@angular/forms": "^21.0.8",
    "@angular/platform-browser": "^21.0.8",
    "@angular/platform-server": "^21.2.17",
    "@angular/pwa": "^21.0.5",
    "@angular/router": "^21.0.8",
    "@angular/service-worker": "^21.0.8",
    "@angular/ssr": "^21.2.17",
    "@apollo/client": "^4.0.12",
    "@huggingface/transformers": "3.8.1",
    "@ng-icons/core": "^33.3.0",
    "@ng-icons/heroicons": "^33.3.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/instrumentation-fetch": "^0.219.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.219.0",
    "@opentelemetry/resources": "^2.3.0",
    "@opentelemetry/sdk-trace-base": "^2.3.0",
    "@opentelemetry/sdk-trace-web": "^2.3.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@tailwindcss/postcss": "^4.1.18",
    "apollo-angular": "^14.1.0",
    "daisyui": "^5.5.14",
    "dexie": "^4.3.0",
    "echarts": "^6.0.0",
    "graphql": "^16.12.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.5",
    "@angular/cli": "^21.0.5",
    "@angular/compiler-cli": "^21.0.8",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typescript": "^5.0.10",
    "@types/jasmine": "~6.0.0",
    "@types/node": "^26.0.1",
    "buffer": "^6.0.3",
    "jasmine-core": "~6.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "prettier": "^3.7.4",
    "strip-json-comments": "^5.0.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  }
}
