{
  "name": "dukarun",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "super-admin",
    "storefront"
  ],
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "setup": "ts-node scripts/setup.ts",
    "predev": "npm run setup -- --quick --fix",
    "dev": "npm run services:up && npm run dev:all",
    "dev:all": "concurrently -k -n BE,FE,SA,ST -c blue,green,magenta,cyan npm:dev:backend npm:dev:frontend npm:dev:super-admin npm:dev:storefront",
    "dev:backend": "npm run dev -w @dukarun/backend",
    "dev:frontend": "npm start -w @dukarun/frontend",
    "dev:super-admin": "npm start -w super-admin",
    "dev:storefront": "npm start -w @dukarun/storefront",
    "codegen": "npm run codegen -w @dukarun/frontend && npm run codegen -w super-admin && npm run codegen -w @dukarun/storefront",
    "codegen:watch": "npm run codegen:watch -w @dukarun/frontend",
    "codegen:super-admin": "npm run codegen -w super-admin",
    "codegen:super-admin:watch": "npm run codegen:watch -w super-admin",
    "codegen:storefront": "npm run codegen -w @dukarun/storefront",
    "codegen:storefront:watch": "npm run codegen:watch -w @dukarun/storefront",
    "services:up": "docker compose -f docker-compose.services.yml -f docker-compose.services.override.yml up -d",
    "services:down": "docker compose -f docker-compose.services.yml -f docker-compose.services.override.yml down",
    "coverage:summary": "node scripts/coverage-summary.mjs --badge-dir badges",
    "test": "npm run test --workspaces --if-present",
    "prepare": "node -e \"if (process.env.CI === 'true' || process.env.HUSKY === '0') process.exit(0); require('child_process').execSync('npx husky install', {stdio:'inherit'})\""
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  }
}
